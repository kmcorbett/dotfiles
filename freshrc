# freshshell.com
# See http://freshshell.com/readme for documentation.

# Update fresh itself
fresh freshshell/fresh bin/fresh --bin

# Zsh inits
fresh home/zshrc --file=~/.zshrc
fresh home/zprofile --file=~/.zprofile

fresh home/signature --file
fresh home/tmux.conf --file=~/.tmux.conf

fresh ssh-config --file=~/.ssh/config

# Emacs
fresh emacs/init.el --file=~/.emacs.d/init.el
# fresh emacs/eval-in-repl-init.el --file=~/.emacs.d/lisp/eval-in-repl-init.el

# Markdown
fresh bin/Markdown.pl --file=~/bin/Markdown.pl

# Starship prompt
fresh config/starship.toml --file=~/.config/starship.toml

# Git — machine-specific gitconfig + shared aliases
fresh git/gitconfig.$(hostname -s) --file=~/.gitconfig --ignore-missing
fresh git/gitconfig.aliases --file=~/.gitconfig.aliases

fresh_after_build() {
    chmod +x ~/bin/Markdown.pl
    echo "++ Git config global user:"
    git config --global --get-regexp '^user.*'
}
